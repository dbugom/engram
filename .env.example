# Copy to .env and adjust as needed. docker-compose sets these for the container;
# this file documents them and is handy for running scripts on the host.

# Host-side default (scripts run outside Docker). Inside Docker, compose uses
# host.docker.internal instead of localhost.
DATABASE_URL=postgresql://postgres:postgres@localhost:54422/postgres
OLLAMA_URL=http://localhost:11434

EMBED_MODEL=qwen3-embedding:4b
EXTRACT_MODEL=qwen3:4b
EMBED_DIM=2560
ENABLE_EXTRACTION=true

# Asymmetric query instruction (Qwen3-Embedding recipe). Set false to disable.
USE_QUERY_INSTRUCTION=true

# --- Noise control ------------------------------------------------------------
# Cosine similarity at/above which a capture counts as a near-duplicate
# (manual captures get a warning; on_near_duplicate=skip refuses to store).
NEAR_DUP_THRESHOLD=0.95
# Threshold for the review_duplicates weekly-review tool (below NEAR_DUP_THRESHOLD
# so it surfaces "should probably consolidate" pairs too).
REVIEW_DUP_THRESHOLD=0.90
# NOTE: OPENBRAIN_MIN_IMPORTANCE (default 3) is read by the auto-capture HOOK on
# the host, not by the server — export it in your shell profile, not here:
#   export OPENBRAIN_MIN_IMPORTANCE=3   # drop auto-captured facts rated below this (1-5)

MCP_HOST=0.0.0.0
MCP_PORT=8000

# --- Cloudflare tunnel (optional; for remote / claude.ai access) -------------
# Token from Cloudflare Zero Trust > Networks > Tunnels > <your tunnel> > Install.
# Copy this file to .env, paste the real token, then:
#   docker compose --profile tunnel up -d
TUNNEL_TOKEN=

# Optional bearer token protecting the REST API (/capture, /search). Required
# once the server is exposed publicly (the auto-capture hook sends it too).
OPENBRAIN_TOKEN=

# --- Google OAuth (for claude.ai remote access) ------------------------------
# From Google Cloud Console > Credentials > OAuth client ID (Web application).
# The registered redirect URI MUST be:  https://openbrain.example.com/auth/callback
# Setting BOTH enables Google OAuth on /mcp (required for claude.ai; also makes
# local Claude Code authenticate via Google).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_BASE_URL=https://openbrain.example.com
